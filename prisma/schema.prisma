generator client {
  provider = "prisma-client-js"
}

// Prisma 7 dropped `url = env(...)` inside schema.prisma — the
// connection URL is now declared in prisma.config.ts (datasource.url)
// for migrations / db push, and passed to `new PrismaClient({ adapter })`
// at runtime via @prisma/adapter-pg.
datasource db {
  provider = "postgresql"
}

model Paper {
  id            String   @id @default(cuid())
  title         String
  abstract      String   @db.Text
  authors       String[]
  year          Int?
  journal       String?
  doi           String?  @unique
  arxivId       String?  @unique
  openAlexId    String?  @unique
  url           String?
  pdfUrl        String?
  isOpenAccess  Boolean  @default(false)
  citationCount Int      @default(0)
  fields        String[]
  keywords      String[]
  submittedVia  String?  @default("agent")
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Back-relation for the talent marketplace: a Paper can be
  // attached to multiple researcher profiles via the ProfilePaper
  // join. Required by Prisma's relation symmetry rule.
  profileLinks    ProfilePaper[]

  // Wiki-layer relations — joins populated by agents/populate-entities.ts
  // from Paper.journal / fields[] / keywords[]. The string columns
  // stay (still used by search) — these are the indexed wiki layer.
  paperTopics       PaperTopic[]
  paperMethods      PaperMethod[]
  paperInstitutes   PaperInstitute[]
  paperResearchers  PaperResearcher[]

  @@index([title])
  @@index([year])
  @@index([citationCount])
}

model Researcher {
  id            String            @id @default(cuid())
  // Unique on name so the extraction agent can bulk-upsert without
  // race-creating duplicate rows for the same author across batches.
  name          String            @unique
  // URL slug for /researchers/[id] vs slug routes. Optional + unique.
  slug          String?           @unique
  // Most-frequent journal home / department guess from the agent.
  // Free-text; populated by extract-entities heuristically (most-
  // common journal across author's papers).
  institution   String?
  email         String?
  website       String?
  paperCount    Int               @default(0)
  // Sum of Paper.citationCount across linked papers — cached at
  // extract time so /researchers/[id] doesn't have to aggregate.
  citationCount Int               @default(0)
  // Top fields the author publishes in (derived from Paper.fields[]).
  fields        String[]
  // Many-to-many to Paper via PaperResearcher join — populated
  // alongside Researcher itself so wiki pages have linked papers.
  papers        PaperResearcher[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// Join table — researcher ↔ paper. Composite primary key prevents
// duplicate links from re-runs of the extraction agent.
model PaperResearcher {
  paperId      String
  researcherId String
  paper        Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)
  researcher   Researcher @relation(fields: [researcherId], references: [id], onDelete: Cascade)

  @@id([paperId, researcherId])
  @@index([researcherId])
}

// ──────────────────────────────────────────────────────────────────
// Talent marketplace — researcher profiles + open positions + AI
// matching. Five new models. All write surfaces (profile creation,
// position posting, application submission) are anonymous + auto-
// live in v1 — same spam-risk profile we discussed for max-robotics
// writes, only sharper here because the data is identity-bearing
// (emails, employers). Adding auth + ownership is the obvious next
// step before this opens to the world.

model ResearchProfile {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  title           String?
  institution     String?
  department      String?
  lab             String?
  country         String?
  website         String?
  bio             String?        @db.Text
  // External identifiers — populated only when the user provides
  // them. orcid is the canonical academic ID and gets @unique so
  // a verified handle can't be claimed twice.
  orcid           String?        @unique
  googleScholarId String?
  twitterHandle   String?
  linkedinUrl     String?
  // researcher | pi | recruiter | student — drives which UI sections
  // render on the profile + which dashboards (matches vs received-
  // applications) make sense for them.
  profileType     String         @default("researcher")
  // Free-text tags: "phd-position", "postdoc", "collaborator",
  // "industry-job". Driving filter chips on the talent hub.
  lookingFor      String[]
  availableFrom   DateTime?
  // Public discovery mode. Defaults to "private" so creating a
  // profile doesn't auto-expose name/employer; users opt in to
  // appearing on the homepage talent rail. Values:
  //   "private"  → counted in aggregate, name not shown
  //   "public"   → full profile rendered with contact links
  //   "open"     → public + signals "actively seeking now"
  visibility      String         @default("private")
  // Granular field-level visibility — when set, only these fields
  // are surfaced on /api/talent/matches public payloads (the page
  // still queries everything; the API redacts). Empty array means
  // "use the visibility column's coarse setting alone".
  visibilityFields String[]      @default([])
  // Link back to the auth User. Optional because most
  // ResearchProfile rows pre-date auth and were auto-extracted /
  // created via /api/talent/profiles.
  userId          String?        @unique
  user            User?          @relation(fields: [userId], references: [id])
  // Self-declared topic + method interests beyond what their papers
  // already imply. Used by the matching engine as a weak signal
  // when the publication footprint is small.
  topics          String[]
  methods         String[]
  // Citation metrics — copy-on-link or computed from the linked
  // Paper rows. Updated by a (future) refresh agent rather than
  // self-reported.
  hIndex          Int            @default(0)
  totalCitations  Int            @default(0)
  paperCount      Int            @default(0)
  papers          ProfilePaper[]
  // Positions the profile has POSTED (PI side).
  positions       Position[]
  // Applications the profile has SENT (applicant side).
  applications    Application[]
  // Match rows pointing at this profile — required Prisma back-
  // relation symmetric to Match.profile.
  matches         Match[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([profileType])
}

// Many-to-many join between ResearchProfile and Paper so a profile
// can claim authorship of multiple papers (and a paper can be
// claimed by multiple co-authors over time).
model ProfilePaper {
  id        String          @id @default(cuid())
  profileId String
  profile   ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  paperId   String
  paper     Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  addedAt   DateTime        @default(now())

  @@unique([profileId, paperId])
  @@index([paperId])
}

model Position {
  id             String          @id @default(cuid())
  title          String
  // phd | postdoc | job | fellowship | grant — drives the type
  // filter on the talent hub.
  type           String
  description    String          @db.Text
  // Topical and methodological keywords used by the matching engine.
  researchTopics String[]
  methods        String[]
  requirements   String[]
  institution    String
  department     String?
  lab            String?
  country        String?
  city           String?
  funded         Boolean         @default(true)
  fundingDetails String?
  salary         String?
  deadline       DateTime?
  startDate      DateTime?
  duration       String?
  contactEmail   String?
  website        String?
  // open | closed | filled — closed positions stop appearing in
  // search but stay readable at /talent/positions/[id].
  status         String          @default("open")
  // Provenance — distinguishes user-posted from crawled rows.
  // Values: "manual" (default; created via /api/talent/positions),
  // "crawled" (agents/crawl-jobs.ts), "import" (one-off batch).
  source         String?         @default("manual")
  // Original URL of the listing page the row was extracted from
  // (vs `website` which is the position's own page when present).
  sourceUrl      String?
  postedById     String
  postedBy       ResearchProfile @relation(fields: [postedById], references: [id], onDelete: Cascade)
  // Optional link to the Employer who owns the position. Set when
  // the position is created via the employer dashboard; null for
  // crawled / manual / mcp-submitted positions.
  employerId     String?
  employer       Employer?       @relation(fields: [employerId], references: [id])
  applications   Application[]
  matches        Match[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status, type])
  @@index([country])
  @@index([deadline])
}

model Application {
  id          String          @id @default(cuid())
  positionId  String
  position    Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   ResearchProfile @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  coverLetter String?         @db.Text
  // pending | shortlisted | rejected | accepted | withdrawn
  status      String          @default("pending")
  // Current pipeline stage — applied | shortlisted | interview |
  // offer | rejected. Distinct from status: status is the lifecycle
  // (open / withdrawn / accepted), stage is where in the funnel.
  stage       String          @default("applied")
  // Employer's private notes on this application — never exposed
  // via candidate-facing API.
  notes       String?         @db.Text
  stages      InterviewStage[]
  // Optional pointer back to the Match row that triggered the
  // application — lets the PI see "why" alongside the application.
  matchId     String?
  match       Match?          @relation(fields: [matchId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([positionId, applicantId])
  @@index([status])
  @@index([stage])
}

model Match {
  id            String          @id @default(cuid())
  positionId    String
  position      Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
  profileId     String
  profile       ResearchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // Composite 0-100 score plus the per-axis breakdown the UI
  // renders as a stacked bar.
  score         Float
  topicScore    Float           @default(0)
  citationScore Float           @default(0)
  methodScore   Float           @default(0)
  venueScore    Float           @default(0)
  reasons       String[]
  sharedTopics  String[]
  sharedMethods String[]
  citedPapers   String[]
  notified      Boolean         @default(false)
  applications  Application[]
  createdAt     DateTime        @default(now())

  @@unique([positionId, profileId])
  @@index([score])
  @@index([profileId, score])
}

// ──────────────────────────────────────────────────────────────────
// Wiki layer — programmatic-SEO surface for journals/topics/methods/
// institutes. Populated for free from existing Paper.journal /
// fields[] / keywords[] data; no Claude calls per paper. Institute
// rows are intentionally unpopulated in v1 (OpenAlex affiliations
// aren't in our current ingest path).
//
// `description` on each entity is reserved for one-shot AI-generated
// summaries cached at write time — NOT generated per page render.

model Journal {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  impactFactor Float?
  paperCount   Int      @default(0)
  description  String?  @db.Text
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // No FK on Paper — journal is matched by name. Saves a backfill
  // pass over 10k+ papers when the populator runs.
}

model Topic {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?      @db.Text
  paperCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  papers      PaperTopic[]

  @@index([paperCount])
}

model Method {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?       @db.Text
  paperCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  papers      PaperMethod[]

  @@index([paperCount])
}

model Institute {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  shortName   String?
  type        String?
  country     String?
  city        String?
  website     String?
  description String?          @db.Text
  paperCount  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  papers      PaperInstitute[]

  @@index([paperCount])
  @@index([country])
}

// Join tables — many-to-many between Paper and the three entity
// types that need it. Journal stays string-matched (one journal per
// paper, no benefit to a separate join row per paper).
model PaperTopic {
  paperId String
  topicId String
  paper   Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([paperId, topicId])
  @@index([topicId])
}

model PaperMethod {
  paperId  String
  methodId String
  paper    Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  method   Method @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@id([paperId, methodId])
  @@index([methodId])
}

model PaperInstitute {
  paperId     String
  instituteId String
  paper       Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@id([paperId, instituteId])
  @@index([instituteId])
}

// ──────────────────────────────────────────────────────────────────
// Search cache — layer 2 of the search route's 3-layer cache stack
// (in-memory → SearchCache → live FTS). queryHash is an md5 of
// {query, filters, matchMode}; @unique gives us upsert-on-hash.
// expiresAt indexed so the cleanup cron can prune fast.

model SearchCache {
  id        String   @id @default(cuid())
  queryHash String   @unique
  query     String
  results   Json
  hitCount  Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────────
// Auth + employer surface — backs NextAuth + the candidate/employer
// dashboards. v1 supports credentials login (email + password
// hashed with bcryptjs) and optional Google OAuth. Resume upload
// to S3 + email verification are planned but deferred — schema is
// here for when they ship.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  // bcryptjs hash. Null for users who only logged in via OAuth.
  password      String?
  image         String?
  // user | employer | admin — drives which dashboard route they
  // land on post-login and what they can do.
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  researchProfile ResearchProfile?
  employer        Employer?
}

// NextAuth.js Account / Session / VerificationToken — exact field
// names required by @auth/prisma-adapter. Don't rename.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Employer {
  id          String     @id @default(cuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgName     String
  // university | company | lab | hospital | other
  orgType     String     @default("university")
  website     String?
  country     String?
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  positions   Position[]
}

// History of stage transitions on an Application. Application.stage
// is the current state; this table is the audit trail with notes +
// scheduled-meeting times.
model InterviewStage {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // applied | shortlisted | interview | offer | rejected
  stage         String
  notes         String?     @db.Text
  scheduledAt   DateTime?
  createdAt     DateTime    @default(now())
  createdBy     String?

  @@index([applicationId])
}
